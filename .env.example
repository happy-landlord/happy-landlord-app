# ─────────────────────────────────────────────────────────────────────────────
# Happy Landlord App — environment variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored; never commit real credentials.
#
# All EXPO_PUBLIC_* variables are bundled into the JS bundle and visible to
# anyone who unpacks the app — keep them to public/anon-safe values only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Google Places ─────────────────────────────────────────────────────────────
# Create a key at: console.cloud.google.com → APIs & Services → Credentials
# Restrict the key to: Android package + iOS bundle id + Places API only.
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=<google-places-api-key>

# ── Sentry ────────────────────────────────────────────────────────────────────
# Used ONLY at build time to upload source maps — never bundled into the app.
# Generate a token at: sentry.io → Settings → Auth Tokens (project:releases scope).
# For CI / EAS cloud builds, store this as an EAS Secret instead:
#   npx eas secret:create --scope project --name SENTRY_AUTH_TOKEN --value <token>
SENTRY_AUTH_TOKEN=<sentry-auth-token>

